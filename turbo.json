{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".cache/tsbuildinfo.json", "dist/**"]
        },
        "dev": {
            "dependsOn": ["^dev"],
            "cache": false,
            "persistent": false
        },
        "lint": {
            "dependsOn": ["^lint"],
            "outputs": [".cache/.eslintcache"]
        },
        "format": {
            "outputs": [".cache/.prettiercache"],
            "outputLogs": "new-only"
        },
        "typecheck": {
            "dependsOn": ["^typecheck"],
            "outputs": [".cache/tsbuildinfo.json"]
        },
        "clean": {
            "cache": false,
            "persistent": true
        }
    }
}
