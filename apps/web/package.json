{
    "name": "@protodo/web",
    "private": true,
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite dev --port 3000",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "clean": "git clean -xdf .cache .turbo .tanstack .content-collections dist node_modules",
        "lint": "eslint --flag unstable_native_nodejs_ts_config",
        "format": "prettier --check . --ignore-path ../../.gitignore",
        "test": "vitest run"
    },
    "dependencies": {
        "@protodo/ui": "workspace:*",
        "@tanstack/react-devtools": "^0.7.0",
        "@tanstack/react-router": "^1.132.0",
        "@tanstack/react-router-devtools": "^1.132.0",
        "@tanstack/router-plugin": "^1.132.0",
        "lucide-react": "^0.545.0",
        "react": "catalog:react19",
        "react-dom": "catalog:react19"
    },
    "devDependencies": {
        "@content-collections/core": "^0.13.1",
        "@content-collections/markdown": "^0.1.4",
        "@content-collections/mdx": "^0.2.2",
        "@content-collections/vite": "^0.2.8",
        "@protodo/eslint-config": "workspace:*",
        "@protodo/prettier-config": "workspace:*",
        "@protodo/tailwind-config": "workspace:*",
        "@protodo/tsconfig": "workspace:*",
        "@tailwindcss/typography": "^0.5.16",
        "@tailwindcss/vite": "catalog:",
        "@tanstack/devtools-vite": "^0.3.11",
        "@tanstack/router-plugin": "^1.132.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.2.0",
        "@types/node": "catalog:",
        "@types/react": "catalog:react19",
        "@types/react-dom": "catalog:react19",
        "@vitejs/plugin-react": "^5.0.4",
        "eslint": "catalog:",
        "jsdom": "^27.0.0",
        "prettier": "catalog:",
        "remark-gfm": "^4.0.1",
        "tailwindcss": "catalog:",
        "typescript": "catalog:",
        "vite": "^7.1.7",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.0.5",
        "zod": "catalog:"
    },
    "prettier": "@protodo/prettier-config"
}
