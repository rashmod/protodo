{
    "extends": "@protodo/tsconfig/base.json",
    "include": ["**/*.ts", "**/*.tsx"],
    "compilerOptions": {
        "jsx": "react-jsx",
        "module": "ESNext",
        "baseUrl": ".",
        "paths": {
            "~/*": ["./src/*"],
            "~/content-collections": ["./.content-collections/generated"]
        },
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],

        /* Bundler mode */
        // "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,

        /* Linting */
        "noUncheckedSideEffectImports": true
    }
}
