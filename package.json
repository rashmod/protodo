{
    "name": "my-turborepo",
    "private": true,
    "packageManager": "pnpm@10.19.0",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "typecheck": "turbo run typecheck",
        "clean": "turbo run clean && git clean -xdf .turbo node_modules",
        "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
        "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
        "format": "turbo run format --continue -- --check",
        "format:fix": "turbo run format --continue -- --write",
        "lint:ws": "pnpm dlx sherif@latest",
        "lint:ws:fix": "pnpm dlx sherif@latest --fix",
        "postinstall": "pnpm lint:ws"
    },
    "devDependencies": {
        "@protodo/prettier-config": "workspace:*",
        "prettier": "catalog:",
        "turbo": "^2.8.9",
        "typescript": "5.9.2"
    },
    "engines": {
        "node": ">=18"
    },
    "prettier": "@protodo/prettier-config"
}
